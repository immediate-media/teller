# Path to the Claude CLI binary. Defaults to 'claude' (i.e. whatever is on PATH).
# Set this if your claude binary is not on PATH, e.g.:
# CLAUDE_BIN=/Users/you/.local/bin/claude
CLAUDE_BIN=

# Anthropic API key — required for briefing and expertise analysis.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for analysis (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Mock mode — bypasses all Claude API and CLI calls, returns fixture data.
# Useful for local dev when no API key is available. Set to 'true' to enable.
# TELLER_MOCK=true

# Atlassian Cloud credentials for the "Who to talk to" feature — used to configure
# an ephemeral mcp-atlassian MCP server the app spawns per request.
# Copy these exact values from ~/.claude.json -> mcpServers["mcp-atlassian"].env
# (do not commit real values — .env.local is gitignored via .env* in .gitignore)
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
