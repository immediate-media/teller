# Anthropic API key — required. Ask your lead or a senior engineer for this.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Atlassian credentials — required for "Who to ask" (searches Jira + Confluence).
# All three values use your standard Atlassian account.
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_URL=https://immediateco.atlassian.net
ATLASSIAN_EMAIL=your.name@immediate.co.uk
ATLASSIAN_API_TOKEN=

# Optional overrides (leave blank to use defaults)
# CLAUDE_MODEL=claude-haiku-4-5        — model used for analysis (default: claude-haiku-4-5)
# CLAUDE_BIN=                           — path to Claude CLI binary, only needed for follow-up threads
# TELLER_MOCK=true                      — bypass all API calls, return fixture data (useful if no API key)
